{
  "opencollection": "1.0.0",
  "info": {
    "name": "OpsLevel GraphQL API",
    "version": "1.0.0"
  },
  "request": {
    "auth": {
      "type": "bearer",
      "token": "{{bearerToken}}"
    }
  },
  "items": [
    {
      "info": {
        "name": "GraphQL",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Execute a GraphQL query or mutation",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.opslevel.com/graphql",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Single endpoint that accepts any OpsLevel GraphQL query or mutation.\nExamples: list services, list teams, run checks, update service\nproperties.\n"
        }
      ]
    }
  ],
  "bundled": true
}